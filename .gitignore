# ===========================================
# Git LFS (Large File Storage)
# ===========================================

# DO NOT ignore these LFS files - they should be committed:
# .gitattributes  (defines which files are tracked by LFS)
# .lfsconfig      (LFS configuration)
# LFS pointer files are handled automatically

# ===========================================
# Data Science & ML
# ===========================================

# Large binary data files (consider using Git LFS for large ones)
# Commented out — small datasets, gene lists, results tables should be trackable
# *.tsv
# *.h5
# *.hdf5
# *.parquet
# *.feather
# *.arrow
# *.db
# *.sqlite
# *.sqlite3

# Large model files (consider using Git LFS for these)
*.model
*.joblib
# *.sav  # commented out — SPSS data files
# *.bin  # commented out — could catch word2vec or custom binary data
*.pt
*.pth
*.onnx
*.safetensors
# checkpoints/  # commented out — too broad

