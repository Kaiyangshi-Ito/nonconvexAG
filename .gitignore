# ===========================================
# Git LFS (Large File Storage)
# ===========================================

# DO NOT ignore these LFS files - they should be committed:
# .gitattributes  (defines which files are tracked by LFS)
# .lfsconfig      (LFS configuration)
# LFS pointer files are handled automatically

